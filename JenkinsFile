pipeline {
    agent any

    environment {
        APP_NAME = "aceest-app"
        DOCKER_IMAGE = "aceest-app:jenkins"
        DOCKER_REGISTRY = "docker.io"
        PUSH_IMAGE = "${env.PUSH_TO_REGISTRY}"
    }

    stages {

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Setup & Install Dependencies') {
            agent { label 'linux' }
            steps {
                sh 'python3 -m venv venv || true'
                sh '. venv/bin/activate && python -m pip install --upgrade pip'
                sh '. venv/bin/activate && pip install -r requirements.txt'
            }
        }

        stage('Run Tests') {
            steps {
                sh '. venv/bin/activate && pytest -q'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh "docker build -t ${DOCKER_IMAGE} ."
            }
        }

        stage('Push Docker Image (Optional)') {
            when {
                expression { return PUSH_IMAGE == "true" }
            }
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker-hub-creds',
                    usernameVariable: 'DOCKER_USERNAME',
                    passwordVariable: 'DOCKER_PASSWORD'
                )]) {

                    sh '''
                    echo $DOCKER_PASSWORD | docker login -u $DOCKER_USERNAME --password-stdin
                    docker tag ${DOCKER_IMAGE} $DOCKER_USERNAME/aceest-app:latest
                    docker push $DOCKER_USERNAME/aceest-app:latest
                    '''
                }
            }
        }
    }
}